{
  "name": "diplomacy",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:rust": "PATH=\"$HOME/.cargo/bin:$PATH\" RUSTUP_TOOLCHAIN=1.88.0 rustup toolchain install 1.88.0 --profile minimal --target wasm32-unknown-unknown && PATH=\"$HOME/.cargo/bin:$PATH\" RUSTUP_TOOLCHAIN=1.88.0 sh -c 'cd rust/diplomacy-wasm && wasm-pack build --target nodejs --out-dir pkg --release'",
    "dev": "bun run build:rust && bunx --bun vite dev",
    "build": "bun run build:rust && bunx --bun vite build",
    "start": "bun run build:rust && bun run server.ts",
    "lint": "bunx --bun oxlint src",
    "lint:fix": "bunx --bun oxlint src --fix",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "shadcn": "bunx --bun shadcn",
    "drizzle": "bunx --bun drizzle-kit",
    "drizzle:generate": "bun drizzle generate",
    "drizzle:migrate": "bun run migrate.ts",
    "drizzle:studio": "bun drizzle-kit studio",
    "type-check": "bun run build:rust && tsgo --noEmit --skipLibCheck",
    "test": "bun run build:rust && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260404.1",
    "@vitejs/plugin-react-swc": "latest",
    "drizzle-kit": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@better-auth/core": "1.6.2",
    "@electric-sql/pglite": "latest",
    "@orpc/client": "latest",
    "@orpc/react-query": "latest",
    "@orpc/server": "latest",
    "@orpc/zod": "latest",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-with-query": "latest",
    "@tanstack/react-start": "latest",
    "better-auth": "1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "drizzle-orm": "latest",
    "drizzle-zod": "latest",
    "lucide-react": "^1.7.0",
    "pg": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-zoom-pan-pinch": "^4.0.3",
    "serialize-error": "latest",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "latest",
    "vite": "latest",
    "zod": "latest"
  }
}
