# Database (optional; when omitted, the app uses a local PGlite database in ./.database/<git-branch>)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplomacy

# Authentication
BETTER_AUTH_SECRET=  # generate with: openssl rand -hex 32
BASE_URL=http://localhost:3000

# Logging
PRETTY_LOGGING=true
DATABASE_DEBUG=false

# Server
PORT=3000
