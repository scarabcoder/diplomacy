# Database (optional; when omitted, the app uses a local PGlite database in ./.database/<git-branch>)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplomacy

# Authentication
BETTER_AUTH_SECRET=  # generate with: openssl rand -hex 32
BASE_URL=http://localhost:3000

# Logging
PRETTY_LOGGING=true
DATABASE_DEBUG=false

# Server
PORT=3000

# AI Bots
BOT_AI_PROVIDER=anthropic  # optional; auto-detects when exactly one provider key is set
ANTHROPIC_API_KEY=  # required when BOT_AI_PROVIDER=anthropic
OPENAI_API_KEY=  # required when BOT_AI_PROVIDER=openai
BOT_AI_MODEL=  # optional; e.g. claude-haiku-4-5 or gpt-5.2
NARRATOR_AI_MODEL=  # optional; falls back to BOT_AI_MODEL when unset
BOT_AI_TAGLINE_MODEL=  # optional; e.g. claude-haiku-4-5 or gpt-5-mini

# Notifications — email (Resend)
RESEND_API_KEY=  # leave empty to log emails to stdout instead of sending
EMAIL_FROM=Diplomacy <notifications@example.com>
PUBLIC_APP_URL=http://localhost:3000  # used to build deep links in emails/pushes

# Notifications — Web Push (VAPID)
# Generate with: bunx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com
